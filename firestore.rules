rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // UserProfile Validation Helper
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'name', 'email']) &&
             data.keys().size() == 3 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 200;
    }

    // RideSession Validation Helper
    function isValidRideSession(data) {
      return data.keys().hasAll(['id', 'date', 'duration', 'maxSpeed', 'avgSpeed', 'distance', 'pevType']) &&
             data.id is string && data.id.size() <= 128 &&
             data.date is string && data.date.size() <= 100 &&
             data.pevType is string && data.pevType.size() <= 100 &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000)) &&
             (!('coordinates' in data) || (data.coordinates is list && data.coordinates.size() <= 100000));
    }

    // RadarBeacon Validation Helper
    function isValidRadarBeacon(data) {
      return data.keys().hasAll(['uid', 'lat', 'lng', 'name']) &&
             data.keys().size() <= 5 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.lat is number &&
             data.lng is number &&
             data.name is string && data.name.size() <= 100 &&
             (!('pevType' in data) || (data.pevType is string && data.pevType.size() <= 100));
    }

    // ForumPost Validation Helper
    function isValidForumPost(data) {
      return data.keys().hasAll(['id', 'author', 'message', 'category']) &&
             data.keys().size() <= 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.author is string && data.author.size() <= 100 &&
             data.message is string && data.message.size() <= 5000 &&
             data.category is string && data.category.size() <= 50 &&
             (!('pevType' in data) || data.pevType is string) &&
             (!('likes' in data) || data.likes is int) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('isLiked' in data) || data.isLiked is bool);
    }

    // ForumReply Validation Helper
    function isValidForumReply(data) {
      return data.keys().hasAll(['id', 'author', 'message']) &&
             data.keys().size() <= 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.author is string && data.author.size() <= 100 &&
             data.message is string && data.message.size() <= 2000 &&
             (!('timestamp' in data) || data.timestamp is string);
    }

    // Meetup Validation Helper
    function isValidMeetup(data) {
      return data.keys().hasAll(['lat', 'lng', 'description', 'setBy', 'timestamp']) &&
             data.keys().size() <= 5 &&
             data.lat is number &&
             data.lng is number &&
             data.description is string && data.description.size() <= 500 &&
             data.setBy is string && data.setBy.size() <= 100 &&
             data.timestamp is int;
    }

    // Ping Validation Helper
    function isValidPing(data) {
      return data.keys().hasAll(['id', 'sender', 'message', 'lat', 'lng', 'timestamp']) &&
             data.keys().size() <= 6 &&
             data.id is string && data.id.size() <= 128 &&
             data.sender is string && data.sender.size() <= 100 &&
             data.message is string && data.message.size() <= 500 &&
             data.lat is number &&
             data.lng is number &&
             data.timestamp is int;
    }

    // BoardPost Validation Helper
    function isValidBoardPost(data) {
      return data.keys().hasAll(['id', 'username', 'userBadge', 'content']) &&
             data.keys().size() <= 8 &&
             data.id is string && data.id.size() <= 128 &&
             data.username is string && data.username.size() <= 100 &&
             data.userBadge is string && data.userBadge.size() <= 100 &&
             data.content is string && data.content.size() <= 5000 &&
             (!('likes' in data) || data.likes is int) &&
             (!('flagged' in data) || data.flagged is bool) &&
             (!('reportsCount' in data) || data.reportsCount is int) &&
             (!('timestamp' in data) || data.timestamp is string);
    }

    // BoardPostReply Validation Helper
    function isValidBoardPostReply(data) {
      return data.keys().hasAll(['id', 'username', 'content']) &&
             data.keys().size() <= 5 &&
             data.id is string && data.id.size() <= 128 &&
             data.username is string && data.username.size() <= 100 &&
             data.content is string && data.content.size() <= 2000 &&
             (!('timestamp' in data) || data.timestamp is string);
    }

    // 1. User Profiles Rules
    match /profiles/{profileId} {
      allow read: if request.auth != null && profileId == request.auth.uid;
      allow create: if request.auth != null && profileId == request.auth.uid && isValidUserProfile(incoming()) && incoming().uid == request.auth.uid;
      allow update: if request.auth != null && profileId == request.auth.uid && isValidUserProfile(incoming()) && incoming().uid == request.auth.uid && incoming().uid == existing().uid;
      allow delete: if false; // profiles are permanent
    }

    // 2. Radar Beacons Rules
    match /radar/{beaconId} {
      allow read: if true;
      allow create, update: if isValidId(beaconId) && isValidRadarBeacon(incoming());
      allow delete: if true;
    }

    // 3. Forum Posts Rules
    match /forum_posts/{postId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidForumPost(incoming());
      allow update: if isValidForumPost(incoming()) && (
        // Allow liking (only likes count can change, and it must change by ±1)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'isLiked']) &&
         (incoming().likes == existing().likes + 1 || incoming().likes == existing().likes - 1))
      );
      allow delete: if false; // Deletion is disabled for forum safety
    }

    // 4. Forum Replies Rules
    match /forum_posts/{postId}/replies/{replyId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidId(replyId) && isValidForumReply(incoming());
      allow update, delete: if false;
    }

    // 5. Meetups Rules
    match /meetups/{meetupId} {
      allow read: if true;
      allow create, update: if isValidId(meetupId) && isValidMeetup(incoming());
      allow delete: if false;
    }

    // 6. Pings Rules
    match /pings/{pingId} {
      allow read: if true;
      allow create: if isValidId(pingId) && isValidPing(incoming());
      allow update, delete: if false;
    }

    // 6b. Board Posts Rules
    match /board_posts/{postId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidBoardPost(incoming());
      allow update: if isValidBoardPost(incoming()) && (
        // Allow liking
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']) &&
         (incoming().likes == existing().likes + 1 || incoming().likes == existing().likes - 1)) ||
        // Allow reporting/flagging (mod review)
        (incoming().diff(existing()).affectedKeys().hasOnly(['flagged', 'reportsCount']) &&
         incoming().flagged == true)
      );
      allow delete: if false;
    }

    // 6c. Board Posts Replies Rules
    match /board_posts/{postId}/replies/{replyId} {
      allow read: if true;
      allow create: if isValidId(postId) && isValidId(replyId) && isValidBoardPostReply(incoming());
      allow update, delete: if false;
    }

    // 7. Connection Test Rules
    match /connection_test/{testId} {
      allow read, write: if true;
    }

    // 8. Ride Logs Rules
    match /ride_logs/{rideId} {
      allow read: if true;
      allow create, update: if isValidId(rideId) && isValidRideSession(incoming());
      allow delete: if true;
    }
  }
}
